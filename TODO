# Код миниконтейнера (container.c)
Чтобы написать мини-контейнер на C, нужно использовать системный вызов clone с флагами изоляции и функцию pivot_root для смены корневой файловой системы.

#define _GNU_SOURCE
#include <sys/types.h>
#include <sys/wait.h>
#include <sys/mount.h>
#include <sys/syscall.h>
#include <sched.h>
#include <stdio.h>
#include <stdlib.h>
#include <unistd.h>

#define STACK_SIZE (1024 * 1024)
static char child_stack[STACK_SIZE];

int pivot_root(const char *new_root, const char *put_old) {
    return syscall(SYS_pivot_root, new_root, put_old);
}

int child_main(void *arg) {
    // 1. Изолируем файловую систему. Делаем монтирования приватными
    mount(NULL, "/", NULL, MS_REC | MS_PRIVATE, NULL);
    // Bind-mount новой корневой папки самой на себя (требование pivot_root)
    mount("./rootfs", "./rootfs", NULL, MS_BIND | MS_REC, NULL);
    
    // 2. Меняем корень на ./rootfs и монтируем старый корень в ./rootfs/old_root
    pivot_root("./rootfs", "./rootfs/old_root");
    chdir("/");

    // 3. Монтируем изолированную /proc для корректной работы ps/top
    mount("proc", "/proc", "proc", 0, NULL);
    
    // 4. Меняем имя хоста внутри контейнера
    sethostname("my-container", 12);

    // 5. Запускаем командную строку внутри контейнера
    char *child_args[] = { "/bin/sh", NULL };
    execv(child_args[0], child_args);
    return 1;
}

int main() {
    printf("Запуск контейнера...\n");
    // Флаги clone создают новые пространства имен: UTS, PID, Mount, IPC, Net
    pid_t child_pid = clone(child_main, child_stack + STACK_SIZE,
        CLONE_NEWUTS | CLONE_NEWPID | CLONE_NEWNS | CLONE_NEWIPC | CLONE_NEWNET | SIGCHLD, NULL);
    
    if (child_pid == -1) {
        perror("Ошибка clone");
        return 1;
    }
    
    waitpid(child_pid, NULL, 0);
    printf("Контейнер остановлен.\n");
    return 0;
}

Как это подготовить и запуститьКонтейнеру нужна своя изолированная файловая система (мини-ОС). Создадим её из слоев текущей системы хоста.bash# 1. Создаем структуру папок для новой корневой системы (rootfs)
mkdir -p rootfs/bin rootfs/lib rootfs/lib64 rootfs/proc rootfs/old_root

# 2. Копируем командный интерпретатор sh и утилиту ls
cp /bin/sh /bin/ls rootfs/bin/

# 3. Копируем зависимости (библиотеки), чтобы sh и ls могли работать
# (Для простоты скопируем основные системные библиотеки)
cp -r /lib/* rootfs/lib/
cp -r /lib64/* rootfs/lib64/

# 4. Компилируем наш C-код
gcc container.c -o container

# 5. Запускаем с правами root (так как управление namespaces требует привилегий)
sudo ./container

Что происходит под капотом за эти 50 строк:
clone(...): Вместо обычной копии процесса (fork), мы создаем новый процесс, но передаем ядру флаги CLONE_NEW*. Ядро выделяет новые структуры в nsproxy (свой сетевой стек, свое дерево PID, свое имя хоста).

mount(..., MS_PRIVATE, ...): Запрещает изменениям монтирования внутри контейнера "утекать" на хост-систему.

pivot_root: Изменяет корневую файловую систему для процесса. Старый корень хоста перемещается в /old_root (ее можно размонтировать для безопасности), а папка ./rootfs становится новым /.mount("proc", ...): Поскольку у нас новый PID Namespace, процесс sh получает внутри контейнера PID 1. Но утилите ps нужно читать файлы из /proc. Мы монтируем туда свежую виртуальную ФС proc, которая видит только процессы этого контейнера.
